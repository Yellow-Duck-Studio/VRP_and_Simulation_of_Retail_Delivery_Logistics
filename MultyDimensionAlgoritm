import pandas as pd
import numpy as np
import os
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import AgglomerativeClustering, DBSCAN

# ==========================================
# 1. ЗАГРУЗЧИК ДАННЫХ
# ==========================================
class DeliveryDataLoader:
    def __init__(self, data_dir: str = "enriched_data"):
        self.data_dir = data_dir
        self.files = {
            'couriers': 'enriched_data/enriched_couriers.csv',
            'orders': 'enriched_data/enriched_orders.csv',
            'warehouses': 'enriched_data/enriched_warehouses.csv'
        }
        self.couriers_df = None
        self.orders_df = None
        self.warehouses_df = None

    def _load_csv(self, file_key: str, parse_dates: list = None) -> pd.DataFrame:
        filename = self.files[file_key]
        filepath = os.path.join(self.data_dir, filename)
        try:
            df = pd.read_csv(filepath, parse_dates=parse_dates)
            print(f"✅ Загружен: {filename} | Строк: {len(df)}")
            return df
        except FileNotFoundError:
            print(f"❌ Файл не найден: {filepath}")
            return pd.DataFrame()

    def load_all(self):
        print("--- Загрузка данных ---")
        self.couriers_df = self._load_csv('couriers')
        
        date_columns = ['pickup_ready_at', 'created_at', 'delivery_deadline_at']
        self.orders_df = self._load_csv('orders', parse_dates=date_columns)
        self.warehouses_df = self._load_csv('warehouses')
        
        return self.couriers_df, self.orders_df, self.warehouses_df

    def get_merged_orders(self) -> pd.DataFrame:
        if self.orders_df is None or self.warehouses_df is None:
            return pd.DataFrame()
        if self.orders_df.empty or self.warehouses_df.empty:
            return pd.DataFrame()
        
        # ИСПРАВЛЕНИЕ: добавляем 'task_id' в составной ключ для merge
        merged_df = pd.merge(
            self.orders_df,
            self.warehouses_df,
            on=['warehouse_id', 'task_id'], 
            how='left',
            suffixes=('_order', '_warehouse') # На случай конфликта других колонок
        )
        
        # Дропаем строки, где нет критически важных для ML данных
        return merged_df.dropna(subset=['order_lat', 'order_lon', 'deadline_ts', 'total_mass_kg'])
# ==========================================
# 2. АЛГОРИТМ КЛАСТЕРИЗАЦИИ
# ==========================================

class DeliveryClusteringPipeline:
    def __init__(self, feature_weights: dict, clustering_model):
        self.feature_weights = feature_weights
        self.clustering_model = clustering_model
        self.scaler = StandardScaler()
        
    def _prepare_features(self, group_df: pd.DataFrame) -> np.ndarray:
        features_to_use = list(self.feature_weights.keys())
        X_raw = group_df[features_to_use].copy()
        
        # Если в группе все значения одинаковые (например, дедлайн у всех один), 
        # StandardScaler выдаст нули, что нормально.
        X_scaled = self.scaler.fit_transform(X_raw)
        weights_array = np.array(list(self.feature_weights.values()))
        return X_scaled * weights_array

    def run(self, orders_df: pd.DataFrame) -> pd.DataFrame:
        if orders_df.empty:
            return orders_df

        # Убедимся, что нужные колонки есть в датафрейме
        if not {'task_id', 'warehouse_id'}.issubset(orders_df.columns):
            raise ValueError("Для строгой изоляции датафрейм должен содержать 'task_id' и 'warehouse_id'")

        result_df = orders_df.copy()
        result_df['cluster_id'] = -1 # По умолчанию все заказы без кластера
        
        # Глобальный счетчик кластеров, чтобы ID не повторялись между складами
        global_cluster_id = 0 

        # Группируем заказы по полигону и складу
        grouped = result_df.groupby(['task_id', 'warehouse_id'])

        for (task_id, warehouse_id), group_df in grouped:
            # Если в группе нет заказов - пропускаем
            if len(group_df) == 0:
                continue
                
            # Если на складе всего 1 заказ, кластеризовать нечего, он сам себе кластер
            if len(group_df) == 1:
                result_df.loc[group_df.index, 'cluster_id'] = global_cluster_id
                global_cluster_id += 1
                continue

            # Подготавливаем фичи ТОЛЬКО для текущего склада и полигона
            X = self._prepare_features(group_df)
            
            # Запускаем кластеризацию
            # Внимание: если используем AgglomerativeClustering и заказов меньше, 
            # чем n_clusters, нужно скорректировать параметр
            try:
                local_labels = self.clustering_model.fit_predict(X)
            except ValueError:
                # Fallback: если заказов слишком мало для выбранного алгоритма, 
                # делаем их одним общим кластером
                local_labels = np.zeros(len(group_df))

            # Делаем локальные ID кластеров глобально уникальными
            unique_labels = np.unique(local_labels)
            label_mapping = {}
            
            for loc_label in unique_labels:
                if loc_label == -1: 
                    # Оставляем шум (от DBSCAN) как -1
                    label_mapping[loc_label] = -1
                else:
                    label_mapping[loc_label] = global_cluster_id
                    global_cluster_id += 1
                    
            # Применяем маппинг к результатам
            global_labels = [label_mapping[l] for l in local_labels]
            
            # Записываем результат обратно в общий датафрейм по индексам группы
            result_df.loc[group_df.index, 'cluster_id'] = global_labels

        return result_df

# ==========================================
# 3. АНАЛИЗАТОР (ВАЛИДАЦИЯ)
# ==========================================
def validate_clusters(clustered_df: pd.DataFrame):
    """Выводит статистику по получившимся кластерам"""
    # Если алгоритм DBSCAN, он помечает шум как -1
    noise_orders = len(clustered_df[clustered_df['cluster_id'] == -1])
    valid_clusters = clustered_df[clustered_df['cluster_id'] != -1]
    
    if valid_clusters.empty:
        print("Внимание: алгоритм не нашел ни одного кластера (все ушло в шум).")
        return

    stats = valid_clusters.groupby('cluster_id').agg(
        total_mass=('total_mass_kg', 'sum'),
        orders_count=('order_id', 'count')
    )
    
    print(f"Всего заказов: {len(clustered_df)} | Не вошли в кластеры (шум): {noise_orders}")
    print(f"Количество сформированных кластеров: {len(stats)}")
    print(f"Средний вес кластера: {stats['total_mass'].mean():.2f} кг")
    print(f"Максимальный вес кластера: {stats['total_mass'].max():.2f} кг")
    print(f"Среднее кол-во заказов в кластере: {stats['orders_count'].mean():.1f}")
    print("-" * 30)

# ==========================================
# 4. ГЛАВНЫЙ МОДУЛЬ (ЭКСПЕРИМЕНТЫ)
# ==========================================
def run_experiment(name: str, df: pd.DataFrame, weights: dict, model):
    print(f"\n▶ ЭКСПЕРИМЕНТ: {name}")
    print(f"Веса фичей: {weights}")
    print(f"Модель: {model}")
    
    pipeline = DeliveryClusteringPipeline(feature_weights=weights, clustering_model=model)
    result_df = pipeline.run(df)
    
    validate_clusters(result_df)
    return result_df

def main():
    # 1. Инициализация и загрузка (замените "." на путь к вашим CSV, если нужно)
    loader = DeliveryDataLoader(data_dir=".")
    loader.load_all()
    
    df_for_ml = loader.get_merged_orders()
    if df_for_ml.empty:
        print("❌ Нет данных для кластеризации. Проверьте файлы.")
        return
        
    print(f"Данные готовы для ML. Всего заказов для распределения: {len(df_for_ml)}")

    # ==========================================
    # БЛОК ТЕСТИРОВАНИЯ ГИПЕРПАРАМЕТРОВ
    # ==========================================
    
    # ЭКСПЕРИМЕНТ 1: Географический приоритет
    # Делаем упор на то, чтобы заказы были физически рядом (для пеших/вело)
    weights_spatial = {
        'order_lat': 3.0, 
        'order_lon': 3.0, 
        'deadline_ts': 0.5, 
        'total_mass_kg': 0.1
    }
    # Допустим, мы хотим получить 10 кластеров
    model_agg_10 = AgglomerativeClustering(n_clusters=10)
    res_1 = run_experiment("Агломеративная кластеризация (Приоритет: География, K=10)", 
                           df_for_ml, weights_spatial, model_agg_10)

    # ЭКСПЕРИМЕНТ 2: Временной приоритет
    # Сильно штрафуем за разницу во времени доставки (для машин с жестким SLA)
    weights_temporal = {
        'order_lat': 1.0, 
        'order_lon': 1.0, 
        'deadline_ts': 4.0, 
        'total_mass_kg': 0.5
    }
    # Меняем количество кластеров на 5
    model_agg_5 = AgglomerativeClustering(n_clusters=5)
    res_2 = run_experiment("Агломеративная кластеризация (Приоритет: Время дедлайна, K=5)", 
                           df_for_ml, weights_temporal, model_agg_5)

    # ЭКСПЕРИМЕНТ 3: Поиск сгустков алгоритмом DBSCAN
    # Ищет естественные "кучи" заказов, отсеивая одиночные заказы как шум
    weights_balanced = {
        'order_lat': 1.5, 
        'order_lon': 1.5, 
        'deadline_ts': 1.5,
        'total_mass_kg': 0.5
    }
    # eps=0.5 означает радиус поиска в нормализованном пространстве
    # min_samples=2 означает, что кластер - это минимум 2 заказа
    model_dbscan = DBSCAN(eps=0.5, min_samples=2)
    res_3 = run_experiment("Плотность DBSCAN (Сбалансированные веса)", 
                           df_for_ml, weights_balanced, model_dbscan)

    # Итог: Вы можете передать результаты (res_1, res_2, res_3) в следующий Блок (Стратегия)
    print("\n✅ Все эксперименты завершены. Результаты готовы для передачи в блок маршрутизации.")

if __name__ == "__main__":
    main()