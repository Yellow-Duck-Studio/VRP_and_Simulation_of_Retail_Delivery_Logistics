{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Simulation Input Data",
  "type": "object",
  "properties": {
    "courier_types": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type_id": { "type": "string" },
          "name": { "type": "string" },
          "capacity_kg": { "type": "number", "exclusiveMinimum": 0 },
          "speed_kmh": { "type": "number", "exclusiveMinimum": 0 }
        },
        "required": ["type_id", "name", "capacity_kg", "speed_kmh"]
      }
    },
    "warehouses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "warehouse_id": { "type": "string" },
          "location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
              "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
              "address": { "type": "string" }
            },
            "required": ["latitude", "longitude"]
          }
        },
        "required": ["warehouse_id", "location"]
      }
    },
    "orders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" },
          "warehouse_id": { "type": "string" },
          "delivery_location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" },
              "address": { "type": "string" }
            },
            "required": ["latitude", "longitude"]
          },
          "delivery_time_window": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" }
            },
            "required": ["start", "end"]
          },
          "status": { "type": "string", "enum": ["pending", "assigned", "in_transit", "delivered", "cancelled"] },
          "mass_kg": { "type": "number", "exclusiveMinimum": 0 },
          "ready_time": { "type": "string", "format": "date-time" }
        },
        "required": ["order_id", "warehouse_id", "delivery_location", "delivery_time_window", "mass_kg", "ready_time"]
      }
    },
    "couriers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "courier_id": { "type": "string" },
          "courier_type_id": { "type": "string" },
          "affiliation_type": { "type": "string", "enum": ["shift", "exchange", "tpl"] },
          "current_location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            },
            "required": ["latitude", "longitude"]
          },
          "current_load": { "type": "number", "minimum": 0 },
          "status": { "type": "string", "enum": ["idle", "loading", "delivering", "returning", "maintenance"] },
          "assigned_order_ids": { "type": "array", "items": { "type": "string" } },
          "current_route_id": { "type": ["string", "null"] },
          "planned_route_ids": { "type": "array", "items": { "type": "string" } },
          "last_updated": { "type": "string", "format": "date-time" }
        },
        "required": ["courier_id", "courier_type_id", "affiliation_type", "current_location"]
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "route_id": { "type": "string" },
          "courier_id": { "type": "string" },
          "warehouse_id": { "type": "string" },
          "start_location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            },
            "required": ["latitude", "longitude"]
          },
          "end_location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            },
            "required": ["latitude", "longitude"]
          },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "total_distance_km": { "type": "number", "minimum": 0 },
          "total_duration_minutes": { "type": "integer", "minimum": 0 },
          "status": { "type": "string" },
          "stops": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "order_id": { "type": "string" },
                "location": {
                  "type": "object",
                  "properties": {
                    "latitude": { "type": "number" },
                    "longitude": { "type": "number" },
                    "address": { "type": "string" }
                  },
                  "required": ["latitude", "longitude"]
                },
                "stop_type": { "type": "string", "enum": ["pickup", "delivery"] },
                "sequence_number": { "type": "integer", "minimum": 1 },
                "service_duration_minutes": { "type": "integer", "minimum": 0, "default": 5 }
              },
              "required": ["order_id", "location", "stop_type", "sequence_number"]
            }
          }
        },
        "required": ["route_id", "courier_id", "warehouse_id", "start_location", "end_location", "start_time", "end_time"]
      }
    },
    "distance_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_id": { "type": "string" },
          "to_id": { "type": "string" },
          "distance": { "type": "number", "minimum": 0 }
        },
        "required": ["from_id", "to_id", "distance"]
      }
    },
    "payment_config": {
      "type": "object",
      "properties": {
        "rate_per_km": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 },
          "default": {}
        },
        "hourly_rate": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 },
          "default": {}
        },
        "window_bonus": { "type": "number", "minimum": 0, "default": 100.0 },
        "base_fee": { "type": "number", "minimum": 0, "default": 0.0 },
        "affiliation_multipliers": {
          "type": "object",
          "properties": {
            "shift": { "type": "number", "minimum": 0, "default": 1.0 },
            "exchange": { "type": "number", "minimum": 0, "default": 1.2 },
            "3pl": { "type": "number", "minimum": 0, "default": 0.9 }
          },
          "additionalProperties": false,
          "default": { "shift": 1.0, "exchange": 1.2, "3pl": 0.9 }
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["courier_types", "warehouses", "orders", "couriers", "routes", "distance_matrix"]
}